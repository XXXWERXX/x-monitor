# ============================================
#  X 推文监控 — 配置文件模板
#  复制此文件为 .env 并填入你的真实信息
#  cp .env.example .env
# ============================================

# ---- QQ 邮箱 SMTP ----
# QQ邮箱 → 设置 → 账户 → POP3/SMTP服务 → 开启 → 获取授权码
SENDER_EMAIL=你的QQ号@qq.com
SENDER_PASSWORD=你的QQ邮箱授权码
RECIPIENT_EMAIL=接收通知的邮箱

# ---- X / Twitter ----
TARGET_SCREEN_NAME=要监控的博主用户名

# ---- 可选: 换用其他邮箱 ----
# SMTP_SERVER=smtp.qq.com
# SMTP_PORT=465
